---
import MobileMenu from './MobileMenu.tsx';
// joshmadakor.tech ワードマーク（黒地ヘッダー用の on-dark=白系・.tech が赤）。
// アウトライン済み SVG なので ?url で読み込み <img> で高さ指定・幅は自動。
import logoUrl from '../assets/images/logo/header-2.svg?url';

// 外部リンク（DesignSpec §3.1）
const IT_TRAINING_URL = 'https://coursecareers.com/joshmadakor';
// Exams は Astro 内部ページ /exams（旧 lognpacific 外部URLから移行）
const EXAMS_URL = '/exams';

// ナビ（現行ライブと同一: Home / IT Training / Cyber Training / Exams / Blog）
const navLinks = [
  { label: 'Home', href: '/', external: false },
  { label: 'IT Training', href: IT_TRAINING_URL, external: true },
  { label: 'Cyber Training', href: '/cyber', external: false },
  { label: 'Exams', href: EXAMS_URL, external: false },
  { label: 'Blog', href: '/blog/', external: false },
];

// active 判定（外部リンクは常に非 active）。'/' は完全一致、それ以外は前方一致。
const path = Astro.url.pathname;
const isActive = (href: string, external: boolean) => {
  if (external) return false;
  return href === '/' ? path === '/' : path.startsWith(href);
};
---

<header id="header" class="sticky top-0 z-50 bg-transparent transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[72px]">
      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label="joshmadakor.tech home">
        <img src={logoUrl} alt="joshmadakor.tech by LogN Pacific" class="h-14 w-auto" loading="eager" />
      </a>

      <!-- Navigation Links (Desktop) -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'text-sm font-normal tracking-wide pb-1 border-b-2 transition',
              isActive(link.href, link.external)
                ? 'text-white border-accent'
                : 'text-gray-200 border-transparent hover:text-white hover:border-accent/60',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right Section -->
      <div class="flex items-center gap-4">
        <!-- SNS Links (現行ヘッダー踏襲) -->
        <div class="hidden sm:flex items-center gap-3">
          <a
            href="https://www.instagram.com/joshmadakor/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37Z" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/joshmadakor/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@JoshMadakor"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition"
            aria-label="YouTube"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.54c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z" />
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#000" />
            </svg>
          </a>
        </div>

        <!-- Mobile Menu Toggle -->
        <MobileMenu exams={EXAMS_URL} itTraining={IT_TRAINING_URL} client:load />
      </div>
    </div>
  </div>
</header>

<style>
  #header {
    background-color: transparent;
  }

  #header.scrolled {
    background-color: rgba(2, 1, 1, 0.85);
    backdrop-filter: blur(12px);
  }
</style>

<script>
  const header = document.getElementById('header');

  function handleScroll() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
