---
// 「↑ back to top」ボタン（ホーム・ブログ等で共用 / DesignSpec §6.1）。
// 400px スクロールで表示。クリックで最上部へスムーススクロール。
---
<button
  id="back-to-top"
  type="button"
  aria-label="Back to top"
  class="fixed bottom-6 right-6 z-40 hidden rounded-full bg-white/10 p-3 text-white backdrop-blur transition hover:bg-white/20"
>
  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');
  function toggleBtn() {
    if (window.scrollY > 400) btn?.classList.remove('hidden');
    else btn?.classList.add('hidden');
  }
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  window.addEventListener('scroll', toggleBtn, { passive: true });
  toggleBtn();
</script>
