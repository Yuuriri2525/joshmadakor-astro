---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

// ブログ一覧のカード（DesignSpec §6.1）。サムネ＋カテゴリバッジ＋タイトル＋抜粋＋READ MORE＋日付。
interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { id, title, description, excerpt, heroImage, category, pubDate } = post.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const summary = excerpt ?? description;
const href = `/blog/${id}/`;
---
<article class="group flex flex-col rounded-xl border border-white/10 bg-white/[0.03] overflow-hidden">
  <a href={href} class="relative block aspect-video overflow-hidden" aria-label={title}>
    {heroImage ? (
      <Image
        src={heroImage}
        alt={title}
        widths={[400, 640, 800]}
        sizes="(min-width: 1024px) 360px, (min-width: 768px) 45vw, 90vw"
        loading="lazy"
        class="w-full h-full object-cover transition duration-300 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-ink to-page"></div>
    )}
    <span class="absolute top-3 right-3 rounded-full bg-black/80 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-white">
      {category}
    </span>
  </a>

  <div class="flex flex-grow flex-col p-5">
    <h2 class="font-heading text-lg font-bold leading-snug text-white">
      <a href={href} class="transition hover:text-brand">{title}</a>
    </h2>
    {summary && (
      <p class="mt-2 line-clamp-3 flex-grow text-sm leading-relaxed text-gray-400">{summary}</p>
    )}
    <a href={href} class="mt-4 inline-flex items-center text-sm font-semibold text-accent hover:underline">
      READ MORE&nbsp;»
    </a>
    <div class="mt-4 border-t border-white/10 pt-4 text-xs text-gray-500">
      <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
    </div>
  </div>
</article>
