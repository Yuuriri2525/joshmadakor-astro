---
// ヘッダーと同一の on-dark ワードマーク（?url + <img>）で黒地フッターへ統一。
import logoUrl from '../assets/images/logo/header-2.svg?url';

// LEARN 列：実在ページ＋確認済み外部URLのみ（存在しないページはリンクしない）。
// IT Training の外部URLは affiliate ref=18242 付き（ユーザー確認済み・改変禁止）。
const EXAMS_URL = '/exams';
const learnLinks = [
  { label: 'IT Training', href: 'https://coursecareers.com/course/it?ref=18242', external: true },
  { label: 'Cyber Training', href: '/cyber', external: false },
  { label: 'Exams', href: EXAMS_URL, external: false },
  { label: 'Blog', href: '/blog/', external: false },
];

// COMPANY 列：会社サイト（lognpacific.com）外部リンク1件のみ。
const companyLinks = [
  { label: 'Company site', href: 'https://lognpacific.com/', external: true },
];
---

<footer class="bg-black text-gray-300 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-[1.3fr_auto_auto_1.6fr] gap-x-12 gap-y-10">
      <!-- Left: brand -->
      <div>
        <img src={logoUrl} alt="joshmadakor.tech by LogN Pacific" class="h-16 w-auto" loading="lazy" />
        <p class="mt-5 text-sm leading-relaxed text-gray-400 max-w-xs">
          Hands-on IT &amp; cybersecurity training — courses, live labs, and exam practice to help you break into tech.
        </p>
        <div class="flex gap-4 mt-6">
          <a
            href="https://www.linkedin.com/in/joshmadakor/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@JoshMadakor"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition"
            aria-label="YouTube"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.54c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z" />
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#000" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/joshmadakor/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37Z" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Middle: LEARN -->
      <nav aria-label="Learn">
        <h3 class="text-xs font-normal tracking-widest text-gray-500 mb-4">LEARN</h3>
        <ul class="flex flex-col gap-3">
          {learnLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="text-sm text-gray-300 hover:text-white transition"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Right: COMPANY -->
      <nav aria-label="Company">
        <h3 class="text-xs font-normal tracking-widest text-gray-500 mb-4">COMPANY</h3>
        <ul class="flex flex-col gap-3">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="text-sm text-gray-300 hover:text-white transition"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Divider + copyright -->
    <div class="border-t border-white/10 mt-12 pt-6">
      <p class="text-xs text-gray-500">&copy; 2026 LogN Pacific. All rights reserved.</p>
    </div>
  </div>
</footer>
