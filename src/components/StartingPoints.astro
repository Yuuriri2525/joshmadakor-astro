---
/*
 * StartingPoints — 「Four ways in. Start wherever you are.」セクション（実装ブリーフ）。
 * カードは非連番・フラット（番号 01/02… や Learn→Practice→Test の手順スレッドは付けない）。
 * データ駆動: 下の typed 配列を ContentCard に流す。順番・コピー・variant はブリーフの指定どおり。
 * リンク先はリポジトリ実値（現行 Header/index の外部リンク・内部ルート）を使用。
 */
import ContentCard from './ContentCard.astro';

// 外部リンク実値（Header.astro と同一）
const IT_TRAINING_URL = 'https://coursecareers.com/joshmadakor';
// IT Exams は Astro 内部ページ /exams（旧 lognpacific 外部URLから移行）
const EXAMS_URL = '/exams';

interface Card {
  title: string;
  kicker?: string;
  description: string;
  href: string;
  ctaLabel: string;
  variant: 'link' | 'button';
  featured?: boolean;
  free?: boolean;
  popular?: boolean;
  external?: boolean;
}

const cards: Card[] = [
  {
    title: 'Cyber Training',
    description: 'Gain hands-on skills and real experience. Launch your career.',
    href: '/cyber',
    ctaLabel: 'View details',
    variant: 'link',
    popular: true,
  },
  {
    title: 'IT Training',
    description: 'Learn in-demand technologies and become a modern IT professional.',
    href: IT_TRAINING_URL,
    ctaLabel: 'View details',
    variant: 'link',
    external: true,
  },
  {
    title: 'IT Exams',
    description: 'Test your skills for free and prepare for certification success.',
    href: EXAMS_URL,
    ctaLabel: 'Take exam now',
    variant: 'button',
    featured: true,
    free: true,
  },
  {
    title: 'Blog',
    description: 'Latest IT trends and expert insights. Keep learning.',
    href: '/blog/',
    ctaLabel: 'Read articles',
    variant: 'link',
  },
];
---

<section class="pt-[34px] pb-[30px]">
  <div class="mx-auto max-w-[1200px] px-7">
    <div class="fade mb-[26px]">
      <span class="font-space text-[.72rem] tracking-[.2em] uppercase text-red">
        Choose your starting point
      </span>
      <h2
        class="mt-3 max-w-[18ch] font-display font-bold text-hi text-[clamp(1.7rem,2.9vw,2.4rem)] leading-[1.05] tracking-[-.02em]"
      >
        Four ways in. Start wherever you are.
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
      {cards.map((card) => <ContentCard {...card} />)}
    </div>
  </div>
</section>
