---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  /** true のとき <meta name="robots" content="noindex"> を出力（404 等・既定 false で他ページ不変） */
  noindex?: boolean;
}

const { title, description, ogImage = '/og-image.png', canonical, noindex = false } = Astro.props;
const siteUrl = 'https://joshmadakor.tech';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - JoshMadakor.tech</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- OGP Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical || siteUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:creator" content="@joshmadakor" />

    <!-- Canonical URL -->
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}

    <!-- フォントは global.css で self-host（@fontsource: Inter / Space Mono / Montserrat 400/600/700）。
         Google Fonts へのホットリンクは廃止（本番は self-host のみ）。 -->

    <!-- Favicons (joshmadakor.tech) -->
    <link rel="icon" type="image/svg+xml" href="/sns-2.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-jm-32.png" />
    <link rel="apple-touch-icon" href="/favicon-jm-180.png" />

    <!-- Google tag (gtag.js) — joshmadakor.tech property (公開値のため直書き) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FYR95RLQXY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FYR95RLQXY');
    </script>
  </head>
  <body class="bg-page text-white font-sans">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  /* body の font-family は global.css の @theme(--font-sans=Montserrat) + base layer で定義。
     ここで system フォントを指定すると（レイヤー無しのため）Tailwind を上書きしてしまうので置かない。 */
</style>
