---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import CyberRangeCTA from '../../components/CyberRangeCTA.astro';
import BackToTop from '../../components/BackToTop.astro';

// 公開記事を新着順に一覧表示（DesignSpec §6.1）。
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Load More 方式（番号送りではない / §6.1）。全カードを出力し、初期 INITIAL 件のみ表示。
// 残りは hidden にしておき、「Load More」で BATCH 件ずつ表示する（JS 最小・依存なし）。
const INITIAL = 12;
const BATCH = 12;
const hasMore = posts.length > INITIAL;
---

<BaseLayout
  title="Blog"
  description="Cyber Security and IT career tips, success stories, and insights from YouTuber Josh Madakor."
>
  <!-- ヘッダー帯（パンくず＋特大見出し＋サブコピー） -->
  <section class="bg-page pt-16 pb-12 sm:pt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2 text-gray-600">›</span>
        <span class="text-gray-300">IT / Cyber Security Blog</span>
      </nav>
      <h1 class="mt-5 font-heading text-5xl font-bold tracking-tight text-white sm:text-6xl">BLOG</h1>
      <p class="mt-4 max-w-2xl text-gray-300">
        Cyber Security and IT career tips, success stories, and insights from YouTuber Josh Madakor.
      </p>
    </div>
  </section>

  <!-- 本体: 記事グリッド（左）＋ サイドバー（右・PCのみ） -->
  <section class="bg-page pb-24">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
      <!-- 記事グリッド -->
      <div class="lg:col-span-8">
        <div id="post-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {posts.map((post, i) => (
            <div class="blog-card-item" data-card hidden={i >= INITIAL}>
              <BlogCard post={post} />
            </div>
          ))}
        </div>

        {hasMore && (
          <div class="mt-12 text-center">
            <button
              id="load-more"
              type="button"
              data-batch={BATCH}
              class="rounded-full border border-white/30 px-8 py-3 text-sm font-semibold tracking-wide text-white transition hover:bg-white hover:text-black"
            >
              Load More
            </button>
          </div>
        )}
      </div>

      <!-- サイドバー -->
      <aside class="hidden lg:col-span-4 lg:block">
        <div class="sticky top-24">
          <CyberRangeCTA />
        </div>
      </aside>
    </div>
  </section>

  <BackToTop />

  <script>
    // Load More: 隠れているカードを BATCH 件ずつ表示。
    // 展開件数とスクロール位置を sessionStorage に保存し、記事から戻ったときに復元する
    //（バグ3: 戻ると初期12件にリセットされる問題への対処）。no-JS では初期12件のまま。
    const btn = document.getElementById('load-more') as HTMLButtonElement | null;
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-card]'));
    const COUNT_KEY = 'blog:loadmore:count';
    const SCROLL_KEY = 'blog:loadmore:scroll';

    if (cards.length) {
      const initialVisible = cards.filter((c) => !c.hasAttribute('hidden')).length || cards.length;
      const batch = btn ? Number(btn.dataset.batch) || initialVisible : initialVisible;

      const reveal = (n: number) => {
        cards.forEach((el, i) => (i < n ? el.removeAttribute('hidden') : el.setAttribute('hidden', '')));
        if (btn) btn.toggleAttribute('hidden', n >= cards.length);
      };

      // 復元: 保存件数（初期件数以上）まで展開
      const savedCount = Number(sessionStorage.getItem(COUNT_KEY)) || 0;
      let shown = Math.min(Math.max(savedCount, initialVisible), cards.length);
      reveal(shown);

      // 展開して戻ってきた場合のみスクロール位置も復元（新規訪問では復元しない）
      if (savedCount > initialVisible) {
        const sy = sessionStorage.getItem(SCROLL_KEY);
        if (sy !== null) requestAnimationFrame(() => window.scrollTo(0, Number(sy)));
      }

      btn?.addEventListener('click', () => {
        shown = Math.min(shown + batch, cards.length);
        reveal(shown);
        sessionStorage.setItem(COUNT_KEY, String(shown));
      });

      // 離脱時（記事リンクのクリック等）にスクロール位置を保存
      window.addEventListener('pagehide', () => sessionStorage.setItem(SCROLL_KEY, String(window.scrollY)));
    }
  </script>
</BaseLayout>
