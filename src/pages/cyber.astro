    <script>
      // 依存なしカルーセル制御（送りボタン / ドット / カウンター）。
      const root = document.querySelector('[data-rw-carousel]');
      if (root) {
        const track = root.querySelector('[data-rw-track]') as HTMLElement;
        const slides = Array.from(root.querySelectorAll('[data-rw-slide]')) as HTMLElement[];
        const dots = Array.from(document.querySelectorAll('[data-rw-dot]')) as HTMLElement[];
        const counter = document.querySelector('[data-rw-counter]');
        const prev = root.querySelector('[data-rw-prev]');
        const next = root.querySelector('[data-rw-next]');
        const total = slides.length;
        let current = 0;

        const render = (i: number) => {
          current = Math.max(0, Math.min(total - 1, i));
          dots.forEach((d, idx) => {
            const on = idx === current;
            d.classList.toggle('w-6', on);
            d.classList.toggle('bg-cyber-accent', on);
            d.classList.toggle('w-2', !on);
            d.classList.toggle('bg-gray-600', !on);
          });
          if (counter) counter.textContent = `${current + 1} / ${total}`;
        };
        const go = (i: number) => {
          const idx = Math.max(0, Math.min(total - 1, i));
          slides[idx]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        };

        prev?.addEventListener('click', () => go(current - 1));
        next?.addEventListener('click', () => go(current + 1));
        dots.forEach((d, idx) => d.addEventListener('click', () => go(idx)));

        // スクロール位置から現在地を追従
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const idx = slides.indexOf(e.target as HTMLElement);
                if (idx >= 0) render(idx);
              }
            });
          },
          { root: track, threshold: 0.6 }
        );
        slides.forEach((s) => io.observe(s));
        render(0);
      }

      // ライトボックス（拡大表示モーダル）。ゼロ依存・カルーセル制御とは独立レイヤー。
      const lb = document.querySelector('[data-rw-lightbox]');
      const lbImg = lb?.querySelector('[data-rw-lb-img]') as HTMLImageElement | null;
      const lbClose = lb?.querySelector('[data-rw-lb-close]');
      const lbPrev = lb?.querySelector('[data-rw-lb-prev]');
      const lbNext = lb?.querySelector('[data-rw-lb-next]');
      const lbCounter = lb?.querySelector('[data-rw-lb-counter]');
      // クリックした画像から開始できるよう、全スライド画像の高解像度版とalt を配列化しておく。
      const lbImages = (Array.from(document.querySelectorAll('[data-rw-image]')) as HTMLImageElement[]).map(
        (img) => ({ full: img.dataset.full || img.currentSrc || img.src, alt: img.alt })
      );
      const lbCount = lbImages.length;

      if (lb && lbImg && lbCount > 0) {
        let currentIndex = 0;

        // 表示中の画像を差し替え。将来スワイプ送りを足しても goToIndex(i) を呼ぶだけで済む。
        const goToIndex = (i: number) => {
          currentIndex = (i + lbCount) % lbCount; // 端はループ（最後→最初 / 最初→最後）
          const item = lbImages[currentIndex];
          lbImg.src = item.full;
          lbImg.alt = item.alt;
          if (lbCounter) lbCounter.textContent = `${currentIndex + 1} / ${lbCount}`;
        };
        const isOpen = () => !lb.classList.contains('hidden');

        const open = (i: number) => {
          goToIndex(i);
          lb.classList.remove('hidden');
          lb.classList.add('flex');
          document.body.style.overflow = 'hidden';
        };
        const close = () => {
          lb.classList.add('hidden');
          lb.classList.remove('flex');
          lbImg.src = '';
          document.body.style.overflow = '';
        };

        // どのスライドの画像をクリックしても、その画像から拡大表示を開始
        (Array.from(document.querySelectorAll('[data-rw-image]')) as HTMLImageElement[]).forEach((img, idx) => {
          img.addEventListener('click', () => open(idx));
        });

        // 前後送り（矢印ボタン）
        lbPrev?.addEventListener('click', () => goToIndex(currentIndex - 1));
        lbNext?.addEventListener('click', () => goToIndex(currentIndex + 1));

        // 閉じる: 1. 背景（画像の外側）クリック
        lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
        // 2. ✕ ボタン
        lbClose?.addEventListener('click', close);
        // キーボード操作: ESC で閉じる / ← → で前後送り（開いている間のみ）
        document.addEventListener('keydown', (e) => {
          if (!isOpen()) return;
          if (e.key === 'Escape') close();
          else if (e.key === 'ArrowLeft') goToIndex(currentIndex - 1);
          else if (e.key === 'ArrowRight') goToIndex(currentIndex + 1);
        });
      }
    </script>
  </section>

