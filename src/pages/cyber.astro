---
import BaseLayout from '../layouts/BaseLayout.astro';

// SCAFFOLD STUB — フェーズ4で /cyber 長尺LP（F2）を忠実に再現する。
// 統計は手動コピーの固定値（SolutionDesign Q6）。
const stats = [
  { value: '200+', label: 'Real Testimonials' },
  { value: '3,500+', label: 'Total Paid Students' },
  { value: '8,800+', label: 'Community Members' },
];

const JOIN_URL = 'https://www.skool.com/cyber-range/about';
---

<BaseLayout
  title="Cyber"
  description="Hands-on cybersecurity training, labs, and community to launch your security career."
>
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight">Break Into Cybersecurity</h1>
    <p class="mt-6 text-lg md:text-xl text-gray-400 max-w-2xl mx-auto">
      Practice real scenarios, build job-ready skills, and join a community that has your back.
    </p>
    <a
      href={JOIN_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-8 px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition"
    >
      Join the Cyber Range
    </a>
  </section>

  <!-- Stats (fixed values, SolutionDesign Q6) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      {stats.map((s) => (
        <div class="p-8 rounded-xl border border-gray-800 bg-gray-800/40">
          <p class="text-4xl font-bold text-white">{s.value}</p>
          <p class="mt-2 text-gray-400">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TODO(Phase4): テスティモニアル / FAQ セクションを実装（F2） -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <h2 class="text-3xl font-bold mb-4">Testimonials &amp; FAQ</h2>
    <p class="text-gray-400">Coming in Phase 4 — testimonials and frequently asked questions.</p>
  </section>
</BaseLayout>
