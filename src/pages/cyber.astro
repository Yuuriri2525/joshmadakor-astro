---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroVideoPoster from '../assets/images/cyber/hero-video-poster.webp';
import winnersPoster from '../assets/images/cyber/winners-interview-poster.webp';
import joshPortrait from '../assets/images/cyber/josh-portrait.webp';

// ⑥/⑦ テスティモニアル画像。
// NOTE: 現状は (A)方式 = PC(md+)で success-01〜06、モバイル(<md)で win-01〜31 を出し分け（現行忠実再現）。
// 同じ就職報告メッセージの表示違いのため、両方を DOM に置くと最大37枚読み込む。
// TODO(将来): (B) 1カルーセルに統一して軽量化する（レスポンシブで1セットのみ読み込む形へ）。
const glob = (g: Record<string, unknown>) =>
  Object.entries(g)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, m]) => (m as { default: ImageMetadata }).default);

const successPc = glob(import.meta.glob('../assets/images/cyber/testimonial/pc/*.webp', { eager: true }));
const winsMobile = glob(import.meta.glob('../assets/images/cyber/testimonial/mobile/*.webp', { eager: true }));

// ⑥ 職種カード（成功者インタビューのサムネ）。video は次メッセージで受領→差し込み。
const roleFiles = import.meta.glob('../assets/images/cyber/job-role/*.webp', { eager: true });
const roleImg = (stem: string) =>
  (Object.entries(roleFiles).find(([p]) => p.endsWith(`${stem}.webp`))![1] as { default: ImageMetadata }).default;
const roles: { label: string; img: ImageMetadata; video: string | null }[] = [
  { label: 'SOC Analyst', img: roleImg('role-soc-analyst'), video: 'https://www.youtube.com/watch?v=QSmMqxkZPOU' },
  { label: 'Cyber Defense Analyst', img: roleImg('role-cyber-defense-analyst'), video: 'https://www.youtube.com/watch?v=MpD3hPAQva8' },
  { label: 'IT Technician', img: roleImg('role-it-technician'), video: 'https://www.youtube.com/watch?v=ecrYhfQTHv4' },
  { label: 'Risk Management Specialist', img: roleImg('role-risk-management-specialist'), video: 'https://www.youtube.com/watch?v=lcbubMvBRUw' },
  { label: 'Remote Cybersecurity Role', img: roleImg('role-remote-cybersecurity'), video: 'https://www.youtube.com/watch?v=3wGTLXZxj6I' },
  { label: 'Cybersecurity Assurance Analyst (DoD)', img: roleImg('role-cybersecurity-assurance-analyst-dod'), video: 'https://www.youtube.com/watch?v=lgFuKt4G77o' },
];

// /cyber 長尺LP（DesignSpec §5）。上から順にセクション実装中。
// 実装済み: C1（ヒーロー / 統計 / Welcome+ツール）
// 未実装: C2 Concerns+Roadmap / C3 Testimonials / C4 Community+Josh / C5 Pricing+FAQ

const JOIN_URL = 'https://www.skool.com/cyber-range/about';
const INTRO_VIDEO_URL = 'https://www.youtube.com/watch?v=RAEHt_sdxZo';
// ⑧ Watch the Winners Interview。Josh のパートが 2629 秒から始まるため t=2629s を維持。
const WINNERS_VIDEO_URL = 'https://www.youtube.com/watch?v=EX-Aa2dermM&t=2629s';

// 統計（確定値・DesignSpec §1 / Q6）。Real Testimonials は実績ギャラリー(#real-wins)へアンカー。
const stats = [
  { value: '200+', label: 'Real Testimonials', href: '#real-wins' },
  { value: '3,500+', label: 'Total Paid Students' },
  { value: '8,800+', label: 'Community Members' },
];

// ツール（テキスト表記・ロゴなし）
const tools = [
  { name: 'Tenable', note: 'Vulnerability Management' },
  { name: 'Microsoft Sentinel', note: 'SIEM' },
  { name: 'Microsoft Defender for Endpoint', note: 'EDR' },
  { name: 'Microsoft Azure', note: 'For Your VMs' },
];

// ⑤ Your Roadmap to Reality（3ステップ）
const roadmap = [
  {
    num: '01',
    title: 'Build Your Foundation',
    desc: 'Master the core skills with our courses in General Theory, Vulnerability Management, and Security Operations. You’ll gain the essential knowledge every cybersecurity professional needs.',
  },
  {
    num: '02',
    title: 'Gain Real-World Experience',
    desc: 'This is where theory becomes reality. Apply your skills in our live Cyber Range, respond to real attacks, and complete internship tasks that you can put directly on your resume.',
  },
  {
    num: '03',
    title: 'Launch Your Career',
    desc: 'With proven experience and a supportive community behind you, you’ll apply to jobs with confidence. We’ll guide you through the job hunt, from application to your first day at work.',
  },
];

// ⑩ Pricing「Ready to Start Your New Career?」（DesignSpec §5 / Q: 料金ハードコード）。
// 月額 $129（ライブ pricing ウィジェット表示に合わせ確定）。FAQ Q2 本文の表記も $129 に統一済み。
// 年額 $1,238（定価 $1,548 / 20% off）。
const pricing = [
  {
    name: 'Monthly Plan',
    price: '$129',
    unit: '/ mo',
    was: null as string | null,
    tagline: 'For those who want to start flexibly. Cancel anytime.',
    cta: 'Start with Monthly',
    highlight: false,
    badge: null as string | null,
  },
  {
    name: 'Annual Plan',
    price: '$1,238',
    unit: '/ yr',
    was: '$1,548',
    tagline: 'For those serious about changing their career. Maximum value.',
    cta: 'Start with Annual',
    highlight: true,
    badge: '20% savings!',
  },
];

// プラン共通の「What you get」（ライブ /cyber の "What you get" コピーを移植 = FAQ Q1 由来）。
// ライブの pricing ウィジェット自体には特典の箇条書きが無いため、ここに共通リストとして配置。
const includes = [
  'Real cybersecurity labs (200+ hours)',
  'Live practice environment where you defend against actual attacks (in a safe, legal setting)',
  'Multiple courses: Security Operations, Vulnerability Management, Threat Hunting',
  'Job prep: Resume building, portfolio creation, interview practice',
  'Access to enterprise-level security tools',
  'Community support (Skool + Discord)',
  'Optional internship',
];

// FAQ 本文中の素朴なURLをクリック可能リンクへ。split の捕捉グループで奇数 index が URL になる。
const URL_RE = /(https?:\/\/[^\s\])]+)/g;
const splitUrls = (text: string) => text.split(URL_RE);

// ⑪ FAQ（ライブ /cyber の JSON-LD FAQPage から正確移植 / 全11件）。
// blocks: 段落(p) と 箇条書き(ul) を保持。アコーディオンは <details>/<summary> でゼロJS。
const faqs: { q: string; blocks: ({ type: 'p'; text: string } | { type: 'ul'; items: string[] })[] }[] = [
  {
    q: 'Is this a course or a bootcamp? Or what is it?',
    blocks: [
      { type: 'p', text: 'It’s neither a traditional course nor a bootcamp. Think of it as a virtual security lab + job-ready training.' },
      { type: 'p', text: 'What you get:' },
      { type: 'ul', items: ['Real cybersecurity labs (200+ hours)', 'Live practice environment where you defend against actual attacks (in a safe, legal setting)', 'Multiple courses: Security Operations, Vulnerability Management, Threat Hunting', 'Job prep: Resume building, portfolio creation, interview practice', 'Access to enterprise-level security tools', 'Community support (Skool + Discord)', 'Optional internship'] },
      { type: 'p', text: 'Format:' },
      { type: 'p', text: 'Monthly subscription. Train at your own pace. Cancel anytime. Keep Discord access forever.' },
      { type: 'p', text: 'Bottom line:' },
      { type: 'p', text: 'You’re not just sitting through lectures — you’re building skills you can prove to employers.' },
    ],
  },
  {
    q: 'How much does this community cost?',
    blocks: [
      { type: 'p', text: 'There are two subscription plans available: a monthly plan at $129 and an annual plan at $1,238. The annual plan offers a 20% discount compared to the monthly rate. If you initially subscribe to the monthly plan, you can later switch to the annual plan. In that case, you will automatically be refunded for one month (this is a feature of the Skool platform).' },
    ],
  },
  {
    q: 'What am I paying for? Isn\'t all information free?',
    blocks: [
      { type: 'p', text: 'All information is free, and it’s important to acknowledge that. However, when you join, here’s what you’re actually paying for:' },
      { type: 'ul', items: ['Access to a Cyber Range Environment that simulates a real work network, shared with other active users. The activity of these participants generates network traffic and logs that you can analyze.', 'Access to enterprise-grade, licensed security tools, including Tenable Vulnerability Management, Microsoft Azure Compute, Microsoft Defender for Endpoint, and an EDR solution.', 'Membership in a professional cybersecurity community with over 1,000 members.', 'Access to a range of individual courses (cybersecurity theory, vulnerability management, security operations, threat hunting, and more) that I have carefully organized and built over time.', 'The rights to list my company on your resume for experience if you choose to participate in the internship program.'] },
    ],
  },
  {
    q: 'Can I really get a job with this?',
    blocks: [
      { type: 'p', text: 'Yes, you can. This community is specifically designed to address the main challenges people face when trying to secure a job, such as gaining hands-on experience in a real-world environment and acquiring verifiable experience that can be added to your resume under a company name. This community builds upon a previous course and internship program that has already helped several individuals land jobs.' },
      { type: 'p', text: 'You can see a list of past interns who have moved on to IT and cybersecurity-related positions here. Every person on this list had Log(N) Pacific (my company) listed as prior experience before securing employment: https://lognpacific.com/past-interns-who-have-gotten-jobs/' },
    ],
  },
  {
    q: 'What technology will I be working with?',
    blocks: [
      { type: 'p', text: 'You will be working with the following:' },
      { type: 'ul', items: ['Cloud Platforms: Microsoft Azure, where you will manage virtual machines, network configurations, and cloud-based resources.', 'Vulnerability Management: Access to enterprise-level tools such as Tenable – Vulnerability Management for scanning, assessing, and managing vulnerabilities in both Windows and Linux environments.', 'Endpoint Detection and Response (EDR): Microsoft Defender for Endpoint, which you will use for onboarding, isolating, and investigating virtual machines, as well as detecting remote code execution.', 'SIEM and Logging Tools: Microsoft Sentinel for creating and visualizing SIEM dashboards, monitoring network activity, and managing logs to identify potential security incidents.', 'Threat Hunting and Security Operations: You’ll engage in threat hunting using scenarios that mimic real-world challenges, such as identifying network slowdowns, detecting data exfiltration, and responding to zero-day threats.', 'Compliance and Auditing: Tools and processes for running compliance audits (e.g., CIS and DISA STIG) and applying security guidelines using PowerShell scripts.', 'Programming and Automation: GitHub for building your portfolio and working on vulnerability management and security operations projects, showcasing your hands-on skills.', 'Monitoring and Forensics: Utilizing Azure Activity Logs, NSG logs, and KQL (Kusto Query Language) to analyze audit logs, network security group logs, and – Microsoft Defender for Endpoint logs.', 'Resume and Career Preparation: Support in building a professional portfolio and resume, along with practical interviewing skills and job search techniques.', 'Internship Component: Optional activities to gain direct, real-world experience under the company’s name, which can be listed on your resume.'] },
      { type: 'p', text: 'This blend of technologies ensures you build a robust set of skills in cybersecurity, including proactive threat response, vulnerability management, and security operations.' },
    ],
  },
  {
    q: 'Is the internship experienced recognized?',
    blocks: [
      { type: 'p', text: 'Yes, the experience is recognized. On average, I provide about one reference per week for companies looking to hire interns. You can view a list of past interns who have successfully transitioned into IT and cybersecurity roles here. Every individual on this list included Log(N) Pacific (my company) as prior experience before securing their positions: [https://lognpacific.com/past-interns-who-have-gotten-jobs/]' },
    ],
  },
  {
    q: 'Why are you charging for an internship?',
    blocks: [
      { type: 'p', text: 'I’m not—the internship is simply an optional component within the community. It initially developed as a response to the high volume of questions and engagement from students. Since then, I’ve enhanced the internship experience by incorporating additional ways for members to contribute and gain experience.' },
    ],
  },
  {
    q: 'What will I be doing during the internship?',
    blocks: [
      { type: 'p', text: 'During the internship, you’ll have the option to engage in various activities, including:' },
      { type: 'ul', items: ['Designing, testing, and publishing Threat Hunting Scenarios for use by other community members.', 'Creating, testing, and publishing Vulnerability Remediations and STIG (Security Technical Implementation Guide) Implementations, which are standardized configurations used to enhance the security of systems.', 'Providing general support within the Skool Cyber Range Community.', 'Offering assistance in the Cyber Range Alumni Discord.'] },
      { type: 'p', text: 'Your role and title will evolve based on your level of contribution, ranging from Cybersecurity Support Technician to Engineering.' },
    ],
  },
  {
    q: 'Can someone completely new do well in the community?',
    blocks: [
      { type: 'p', text: 'Yes, absolutely. There is an entire section dedicated to providing resources and advice to help you build a strong foundation in cybersecurity. While the learning curve for someone completely new can be steep, it’s definitely manageable. Additionally, if you’re just starting out in the field, it’s highly encouraged to apply for both general IT positions and cybersecurity roles to increase your experience and opportunities.' },
    ],
  },
  {
    q: 'What if I bought your previous course? Can I get a discount?',
    blocks: [
      { type: 'p', text: 'All original course members were notified via email at the launch of the program and given the opportunity to join at a discounted rate. Once you join at this price, your rate will be locked in. Additionally, all original course members were granted access to the Cyber Range Alumni Discord, regardless of whether they choose to join the new community.' },
    ],
  },
  {
    q: 'How is the new Cyber Range Community different from the previous Course?',
    blocks: [
      { type: 'p', text: 'The new Cyber Range is a hands-on, community-driven environment built for real-world IT and cybersecurity training. Unlike the old self-paced video course, this upgraded platform lets students work together in the same network using real enterprise tools like Tenable for vulnerability management and Microsoft Defender for Endpoint for threat hunting on Azure. It offers guided labs, mentorship, resume and career support, plus internship tasks in vulnerability management and threat hunting that you can complete on your own to earn credit. With structure, accountability, and access to industry tools, the Cyber Range Community is designed to give you practical skills, confidence, and the support you need to get hired.' },
    ],
  },
];
---

<BaseLayout
  title="Cyber"
  description="Live-Fire Cyber Range with a hands-on cyber course for each security operations topic. Real labs, real tools, real internships."
>
  <!-- ① ヒーロー -->
  <section class="bg-page py-20 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading font-bold text-white text-3xl sm:text-4xl lg:text-5xl leading-tight">
        🎯 Welcome to the Cyber Range
      </h1>
      <p class="mt-5 text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto">
        Live-Fire Cyber Range with a Hands-On Cyber Course for Each Security Operations Topic!
      </p>

      {/* 紹介動画: サムネ＋再生ボタン → YouTube（新規タブ）。iframe 不使用で軽量。 */}
      <a
        href={INTRO_VIDEO_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Watch the Cyber Range intro video on YouTube"
        class="group relative block max-w-2xl mx-auto mt-10 rounded-xl overflow-hidden border border-white/10"
      >
        <Image
          src={heroVideoPoster}
          alt="Cyber Range intro video"
          widths={[480, 768, 1280]}
          sizes="(max-width: 768px) 100vw, 672px"
          class="w-full h-auto block"
        />
        <span class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition">
          <span class="flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-white/90 group-hover:bg-white shadow-lg transition">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-black ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </a>

      <a
        href={JOIN_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-8 rounded-full bg-gradient-to-r from-btn-start to-btn-end px-8 py-3 text-white text-sm font-semibold tracking-wide transition hover:brightness-110"
      >
        Get Started Now
      </a>
    </div>
  </section>

  <!-- ② 統計3カウンタ -->
  <section class="bg-page pb-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        {stats.map((s) => {
          const inner = (
            <>
              <p class="font-heading font-bold text-brand text-4xl sm:text-5xl">{s.value}</p>
              <p class="mt-2 text-gray-200">{s.label}</p>
            </>
          );
          return (
            <div class="rounded-xl border border-white/10 bg-white/[0.03] p-8">
              {s.href ? <a href={s.href} class="block hover:opacity-90 transition">{inner}</a> : inner}
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ③ Welcome / Cyber Internships + ツール -->
  <section class="bg-page pb-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl leading-tight">
        Welcome to The Cyber Range! <span class="text-brand">(Cyber Internships Available)</span>
      </h2>
      <p class="mt-5 text-gray-200 max-w-3xl mx-auto leading-relaxed">
        As a community member, you'll have access to a LIVE production SOC (Security Operations Center)
        where you will gain experience using fully licensed, enterprise-grade cybersecurity tools.
      </p>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {tools.map((t) => (
          <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5 text-center">
            <p class="font-heading font-bold text-white">{t.name}</p>
            <p class="mt-1 text-sm text-gray-400">{t.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ Do you have these concerns?（強調Q&A 3件） -->
  <section class="bg-page py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center mb-10">
        Do you have these concerns?
      </h2>

      <div class="space-y-6">
        <!-- Q1 -->
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 sm:p-8">
          <h3 class="font-heading font-bold text-brand text-lg sm:text-xl">
            Can I get the cybersecurity job with zero experience?
          </h3>
          <p class="mt-3 text-gray-200 leading-relaxed">
            Yes — it's possible. <strong class="text-white">58% of Cyber Range graduates</strong> land
            cybersecurity roles directly. The other 42% start in tech roles that lead into security. You
            get hands-on labs that simulate real job tasks, plus resume and interview prep. We support you
            from skill-building all the way to job hunting. It takes effort. But this is the shortest path.
          </p>
          <a href="#real-wins" class="inline-block mt-4 text-accent hover:underline text-sm font-semibold">
            👉 See real success stories
          </a>
        </div>

        <!-- Q2 -->
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 sm:p-8">
          <h3 class="font-heading font-bold text-brand text-lg sm:text-xl">
            Does this program provide a clear roadmap from zero to getting hired?
          </h3>
          <p class="mt-3 text-gray-200 leading-relaxed">
            Yes. Cyber Range comes with a clear, structured roadmap you can follow step by step. You'll
            know exactly <strong class="text-white">what to learn, in what order, and why</strong> — from
            repeating labs the right way, to building a resume and portfolio that actually reflects
            real-world skills. Instead of guessing what to study next, you'll move forward with confidence,
            knowing each step is preparing you for interviews and real job requirements.
          </p>
          <a href="#real-wins" class="inline-block mt-4 text-accent hover:underline text-sm font-semibold">
            👉 See real success stories
          </a>
        </div>

        <!-- Q3 -->
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 sm:p-8">
          <h3 class="font-heading font-bold text-brand text-lg sm:text-xl">
            Is this truly worth it for my future?
          </h3>
          <p class="mt-3 text-gray-200 leading-relaxed">
            Cybersecurity isn't a short-term trend — it's a field that keeps growing and evolving. Even
            with AI and automation advancing, companies still need skilled humans to investigate threats,
            respond to incidents, and protect systems. Cyber Range helps you invest your time and energy in
            <strong class="text-white">practical, future-proof skills</strong>. If you're willing to
            consistently show up, practice, and learn, this program can change you from “interested in
            cybersecurity” to someone who actually has
            <strong class="text-white">hands-on experience and job-ready confidence</strong>.
          </p>
          <a href="#real-wins" class="inline-block mt-4 text-accent hover:underline text-sm font-semibold">
            → See real success stories
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ⑤ Your Roadmap to Reality（3ステップ） -->
  <section class="bg-page py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center mb-12">
        Your Roadmap to Reality
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {roadmap.map((step) => (
          <div class="rounded-xl border border-white/10 bg-white/[0.03] p-8">
            <p class="font-heading font-bold text-accent text-4xl">{step.num}</p>
            <h3 class="font-heading font-bold text-white text-xl mt-3">{step.title}</h3>
            <p class="mt-3 text-gray-300 leading-relaxed text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ Success Stories & Graduate Voices（職種インタビューのサムネ6枚） -->
  <section class="bg-page py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center mb-12">
        Success Stories &amp; Graduate Voices
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {roles.map((role) => {
          const thumb = (
            <span class="group relative block rounded-xl overflow-hidden border border-white/10">
              <Image
                src={role.img}
                alt={`${role.label} — graduate interview`}
                widths={[400, 640]}
                sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 90vw"
                loading="lazy"
                class="w-full h-auto block"
              />
              <span class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition">
                <span class="flex items-center justify-center w-14 h-14 rounded-full bg-white/90 group-hover:bg-white shadow-lg transition">
                  <svg class="w-6 h-6 text-black ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </span>
            </span>
          );
          return (
            <div>
              {role.video ? (
                <a href={role.video} target="_blank" rel="noopener noreferrer" aria-label={`Watch ${role.label} interview on YouTube`}>
                  {thumb}
                </a>
              ) : (
                thumb
              )}
              <p class="mt-3 text-center font-heading font-semibold text-white">{role.label}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ⑦ Real Wins from the Community（報告カルーセル / id=real-wins = C2のアンカー先） -->
  <section id="real-wins" class="bg-page py-20 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center">
        Real Wins from the Community
      </h2>
      <p class="mt-3 text-center text-gray-300">This isn't just a dream. It's a reality.</p>
    </div>

    {/* (A)方式: PC は success-01〜06、モバイルは win-01〜31 を出し分け。両方 CSS scroll-snap 横カルーセル。 */}
    <!-- PC（md+） -->
    <div class="hidden md:flex mt-12 gap-6 overflow-x-auto snap-x snap-mandatory px-4 sm:px-6 lg:px-8 pb-4">
      {successPc.map((img, idx) => (
        <div class="snap-center shrink-0 w-[60%] lg:w-[32%]">
          <Image
            src={img}
            alt={`Graduate success story ${idx + 1}`}
            widths={[480, 720]}
            sizes="(min-width: 1024px) 32vw, 60vw"
            loading="lazy"
            class="w-full h-auto rounded-xl border border-white/10"
          />
        </div>
      ))}
    </div>

    <!-- モバイル（<md） -->
    <div class="flex md:hidden mt-10 gap-4 overflow-x-auto snap-x snap-mandatory px-4 pb-4">
      {winsMobile.map((img, idx) => (
        <div class="snap-center shrink-0 w-[78%]">
          <Image
            src={img}
            alt={`Community win ${idx + 1}`}
            widths={[320, 480]}
            sizes="78vw"
            loading="lazy"
            class="w-full h-auto rounded-xl border border-white/10"
          />
        </div>
      ))}
    </div>
  </section>

  <!-- ⑧ #1 Community in Skool Games + Watch the Winners Interview -->
  <section class="bg-page py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 rounded-full border border-accent/40 bg-accent/10 px-5 py-2 text-accent font-heading font-bold tracking-wide">
        🏆 #1 Community in Skool Games
      </span>
      <p class="mt-5 text-gray-200 max-w-2xl mx-auto leading-relaxed">
        The Cyber Range was ranked the <strong class="text-white">#1 community</strong> in the Skool Games —
        out of thousands of communities on the platform. Hear directly from the winners.
      </p>

      {/* Watch the Winners Interview: サムネ＋再生ボタン → YouTube（新規タブ・t=2629s 維持）。iframe 不使用で軽量。 */}
      <a
        href={WINNERS_VIDEO_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Watch the Winners Interview on YouTube"
        class="group relative block max-w-2xl mx-auto mt-10 rounded-xl overflow-hidden border border-white/10"
      >
        <Image
          src={winnersPoster}
          alt="Watch the Winners Interview"
          widths={[480, 768, 1280]}
          sizes="(max-width: 768px) 100vw, 672px"
          loading="lazy"
          class="w-full h-auto block"
        />
        <span class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition">
          <span class="flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-white/90 group-hover:bg-white shadow-lg transition">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-black ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </a>
      <p class="mt-4 text-sm font-heading font-semibold text-white">▶ Watch the Winners Interview</p>
    </div>
  </section>

  <!-- ⑨ A Word From Josh / His Journey & Expertise -->
  <section class="bg-page py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-14 items-center">
        <!-- ポートレート -->
        <div class="flex justify-center md:justify-end">
          <Image
            src={joshPortrait}
            alt="Josh Madakor"
            widths={[400, 640]}
            sizes="(min-width: 768px) 420px, 80vw"
            loading="lazy"
            class="w-full max-w-sm h-auto rounded-2xl border border-white/10"
          />
        </div>

        <!-- 本文 -->
        <div>
          <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl leading-tight">
            A Word From Josh
          </h2>
          <blockquote class="mt-5 border-l-2 border-accent pl-5 text-gray-100 text-lg leading-relaxed italic">
            “For 15 years, I was obsessed with one thing: skill stacking. I got really good at understanding
            what employers want. This course is everything I learned, condensed into a direct path, so you
            don't have to spend 15 years figuring it out yourself.”
          </blockquote>

          <h3 class="mt-8 font-heading font-bold text-brand text-xl">His Journey &amp; Expertise</h3>
          <p class="mt-3 text-gray-300 leading-relaxed">
            Josh Madakor started his IT career in 2007 as a help desk technician and has since developed
            expertise in software development, system engineering, and cybersecurity. He has worked across
            multiple industries including government, finance, defense, and private sector — notably as a
            <strong class="text-white">Microsoft contractor</strong>, where he contributed to the Microsoft
            Cloud Security Benchmark.
          </p>
          <p class="mt-4 text-gray-300 leading-relaxed">
            Since 2020, Josh has grown his YouTube channel to <strong class="text-white">over 200,000
            subscribers</strong>, helping individuals advance their IT and cybersecurity careers through
            educational content.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ⑩ Pricing「Ready to Start Your New Career?」 -->
  <section class="bg-page py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center">
        Ready to Start Your New Career?
      </h2>

      {/* プラン共通の同梱内容（ライブ "What you get" コピー） */}
      <div class="mt-10 max-w-2xl mx-auto rounded-xl border border-white/10 bg-white/[0.03] p-6 sm:p-8">
        <p class="font-heading font-bold text-white text-center">Every plan includes</p>
        <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
          {includes.map((item) => (
            <li class="flex items-start gap-2 text-gray-200 text-sm">
              <span class="text-accent mt-0.5">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {pricing.map((plan) => (
          <div
            class:list={[
              'relative flex flex-col rounded-2xl border p-8 text-center',
              plan.highlight ? 'border-brand bg-brand/[0.06]' : 'border-white/10 bg-white/[0.03]',
            ]}
          >
            {plan.badge && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-btn-start to-btn-end px-4 py-1 text-xs font-semibold text-white">
                {plan.badge}
              </span>
            )}
            <p class="font-heading font-bold text-white text-lg">{plan.name}</p>
            <div class="mt-4 flex items-end justify-center gap-1">
              {plan.was && <span class="text-gray-500 line-through text-lg mb-1">{plan.was}</span>}
              <span class="font-heading font-bold text-brand text-4xl sm:text-5xl">{plan.price}</span>
              <span class="text-gray-300 mb-1">{plan.unit}</span>
            </div>
            <p class="mt-4 text-gray-300 text-sm flex-grow">{plan.tagline}</p>
            <div class="mt-6">
              <a
                href={JOIN_URL}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  'inline-block w-full rounded-full px-6 py-3 text-sm font-semibold tracking-wide transition',
                  plan.highlight
                    ? 'bg-gradient-to-r from-btn-start to-btn-end text-white hover:brightness-110'
                    : 'border border-white/30 text-white hover:bg-white hover:text-black',
                ]}
              >
                {plan.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑪ FAQ（<details>/<summary> でゼロJSアコーディオン / 全11件） -->
  <section class="bg-page py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-white text-2xl sm:text-3xl text-center mb-12">
        Frequently Asked Questions
      </h2>

      <div class="space-y-4">
        {faqs.map((item) => (
          <details class="group rounded-xl border border-white/10 bg-white/[0.03] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-5 sm:p-6 [&::-webkit-details-marker]:hidden">
              <span class="font-heading font-semibold text-white">{item.q}</span>
              <svg
                class="w-5 h-5 flex-shrink-0 text-accent transition-transform duration-200 group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 sm:px-6 pb-6 -mt-1 space-y-3 text-gray-300 leading-relaxed">
              {item.blocks.map((block) =>
                block.type === 'p' ? (
                  <p>
                    {splitUrls(block.text).map((part, idx) =>
                      idx % 2 === 1 ? (
                        <a href={part} target="_blank" rel="noopener noreferrer" class="text-brand underline break-words hover:text-brand/80">{part}</a>
                      ) : (
                        part
                      )
                    )}
                  </p>
                ) : (
                  <ul class="list-disc pl-5 space-y-1.5">
                    {block.items.map((li) => (
                      <li>
                        {splitUrls(li).map((part, idx) =>
                          idx % 2 === 1 ? (
                            <a href={part} target="_blank" rel="noopener noreferrer" class="text-brand underline break-words hover:text-brand/80">{part}</a>
                          ) : (
                            part
                          )
                        )}
                      </li>
                    ))}
                  </ul>
                )
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
