---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StartingPoints from '../components/StartingPoints.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
---

<BaseLayout
  title="Home"
  description="Hands-on cybersecurity and IT training, certification practice, and career insights from LogN Pacific."
>
  <!--
    ホーム再設計（実装ブリーフ）。ホーム限定のダークトークン＋Inter/Montserrat(display)/Space を適用。
    共通 Header/Footer はそのまま（他ページと統一）。sticky ヘッダーは CSS、フェードは任意の
    CSS のみで prefers-reduced-motion でオフ。ゼロ JS。
  -->
  <div class="bg-night font-inter text-hi overflow-x-hidden">
    <Hero />
    <StartingPoints />
    <ClosingCTA />
  </div>
</BaseLayout>

<style>
  /* 読み込み時のフェードイン（任意・CSS のみ / reduced-motion でオフ） */
  :global(.fade) {
    opacity: 0;
    transform: translateY(14px);
    animation: fade 0.7s ease forwards;
  }
  :global(.fade.d1) {
    animation-delay: 0.05s;
  }
  :global(.fade.d2) {
    animation-delay: 0.13s;
  }
  @keyframes fade {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.fade) {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
