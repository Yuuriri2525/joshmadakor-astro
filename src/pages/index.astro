---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';

// SCAFFOLD STUB — フェーズ4で Elementor 版ホーム（F1）を忠実に再現する。
// F1: ヒーロー + 4カードナビ + CONTACT。

const cards = [
  { title: 'Cyber', desc: 'Hands-on cybersecurity training and community.', href: '/cyber', external: false },
  { title: 'Blog', desc: 'Articles on IT, security, and career growth.', href: '/blog/', external: false },
  { title: 'IT Exams', desc: 'Free certification practice tests.', href: 'https://lognpacific.com/free-certification-practice-tests/', external: true },
  { title: 'IT Training', desc: 'Break into IT with a structured course.', href: 'https://coursecareers.com/joshmadakor', external: true },
];
---

<BaseLayout
  title="Home"
  description="Josh Madakor — helping people launch and grow careers in IT and cybersecurity."
>
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight">Josh Madakor</h1>
    <p class="mt-6 text-lg md:text-xl text-gray-400 max-w-2xl mx-auto">
      Launch and grow your career in IT and cybersecurity — with training, community, and hands-on practice.
    </p>
  </section>

  <!-- 4-card navigation -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {cards.map((card) => (
        <a
          href={card.href}
          target={card.external ? '_blank' : undefined}
          rel={card.external ? 'noopener noreferrer' : undefined}
          class="block p-6 rounded-xl border border-gray-800 bg-gray-800/40 hover:border-gray-600 hover:bg-gray-800 transition"
        >
          <h2 class="text-xl font-semibold text-white">{card.title}</h2>
          <p class="mt-2 text-gray-400 text-sm">{card.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <h2 class="text-3xl font-bold text-center mb-8">Get in touch</h2>
    <div class="bg-gray-800/40 border border-gray-800 rounded-xl p-6 md:p-10">
      <ContactForm client:load />
    </div>
  </section>
</BaseLayout>
