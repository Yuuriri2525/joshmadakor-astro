<script>
  // Video thumbnail facade → クリックで Loom を読み込み再生（intent まで Loom を読み込まない=perf）
  document.querySelectorAll('[data-video]').forEach((wrap) => {
    const btn = wrap.querySelector('.video-facade');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src = 'https://www.loom.com/embed/ceec1d1c1e3f4549b9b5a236654033c8?autoplay=1';
      iframe.title = 'Practice Exam walkthrough';
      iframe.loading = 'lazy';
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('allow', 'autoplay; fullscreen');
      iframe.setAttribute('allowfullscreen', '');
      wrap.replaceChildren(iframe);
    }, { once: true });
  });
</script>
